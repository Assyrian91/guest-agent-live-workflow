      "parameters": {
        "description": "Use this tool to look up a guest's booking details by their booking reference number. The input should be just the reference, e.g. BK1001.",
        "jsCode": "const bookings = {\n  \"BK1001\": { guest: \"John Smith\", checkIn: \"2026-07-01\", checkOut: \"2026-07-05\", room: \"Deluxe Room\", status: \"Confirmed, paid in full\" },\n  \"BK1002\": { guest: \"Sarah Lee\", checkIn: \"2026-07-10\", checkOut: \"2026-07-12\", room: \"Standard Room\", status: \"Confirmed, payment pending\" },\n  \"BK1003\": { guest: \"Ahmed Khalil\", checkIn: \"2026-08-01\", checkOut: \"2026-08-03\", room: \"Suite\", status: \"Confirmed, paid in full\" },\n  \"BK1004\": { guest: \"Maria Garcia\", checkIn: \"2026-07-15\", checkOut: \"2026-07-18\", room: \"Standard Room\", status: \"Confirmed, paid in full\" }\n};\n\nconst ref = query.trim().toUpperCase();\nconst booking = bookings[ref];\n\nif (!booking) {\n  return `No booking found with reference ${ref}. Please double check the reference number.`;\n}\n\nreturn `Booking ${ref}: ${booking.guest}, ${booking.room}, check-in ${booking.checkIn}, check-out ${booking.checkOut}. Status: ${booking.status}.`;"
      },
